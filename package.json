    "@sveltejs/kit": "^2.69.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^26",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "mdsvex": "^0.12.7",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": ">=5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1",
